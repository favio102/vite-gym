{
  "rewrites": [
    {
      "source": "/api/exercisedb/:path*",
      "destination": "/api/proxy?provider=exercisedb&path=:path*"
    },
    {
      "source": "/api/youtube/:path*",
      "destination": "/api/proxy?provider=youtube&path=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
